{
  "name": "backend",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "oxlint .",
    "test": "rm -rf .data && mkdir -p .data && bun test",
    "test:coverage": "rm -rf .data && mkdir -p .data && bun test --coverage",
    "build:standalone": "bun build --compile --minify --sourcemap --outfile dist/tasker-standalone src/index.ts"
  },
  "dependencies": {
    "shared-contract": "workspace:*"
  }
}