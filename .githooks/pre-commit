#!/bin/sh

echo "======================================"
echo "    Running pre-commit CI checks      "
echo "======================================"

# Determine if moon is available natively
if command -v moon >/dev/null 2>&1; then
  MOON_CMD="moon"
else
  # Fallback to npx executing local or global moon
  MOON_CMD="npx --no-install moon"
fi

echo "Running checks via moon (this will be instant if cached)..."

# Run ALL project checks (lint, format, test, typecheck, build) to guarantee CI success
$MOON_CMD check --all
if [ $? -ne 0 ]; then
  echo "❌ Pre-commit checks failed. Please fix before committing."
  exit 1
fi

echo "✅ Pre-commit tasks completed."
echo "======================================"
echo "    All Local Checks Passed! 🚀       "
echo "======================================"
